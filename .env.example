# Production (Vercel): point at your Turso database.
# Locally these are unset and the app uses a file DB at data/ledgerai.db.
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional: overrides the demo session signing secret (Vercel can auto-generate one).
# SESSION_SECRET=change-me
